<?xml version="1.0" encoding="utf-8"?>
<robot name="arm">
  <!-- 材质定义 -->
  <material name="red"><color rgba="1 0 0 1"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="white"><color rgba="1 1 1 1"/></material>
  <material name="green"><color rgba="0 1 0 1"/></material>
  <material name="yellow"><color rgba="1 1 0 1"/></material>

  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://fishbot_description/meshes/base_link.STL" /></geometry>
      <material name="red"/>
    </visual>
    <!-- 蓝色标记块 -->
    <visual>
      <origin xyz="0.05 0 0.005" rpy="0 0 0" />
      <geometry><box size="0.02 0.02 0.01" /></geometry>
      <material name="green"/>
    </visual>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://fishbot_description/meshes/link1.STL" /></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0 0 0.024" rpy="0 0 1.5708" />
    <parent link="base_link" />
    <child link="link1" />
    <axis xyz="0 0 -1" />
    <limit lower="-3.14" upper="3.14" effort="10" velocity="3" />
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://fishbot_description/meshes/link2.STL" /></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <origin xyz="0 -0.0090485 0.008" rpy="1.5708 0 0" />
    <parent link="link1" />
    <child link="link2" />
    <axis xyz="0 0 -1" />
    <limit lower="-3.14" upper="3.14" effort="10" velocity="3" />
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://fishbot_description/meshes/link3.STL" /></geometry>
      <material name="green"/>
    </visual>
  </link>

  <joint name="joint3" type="revolute">
    <origin xyz="0 0.030167 -0.01945" rpy="-3.1416 0 3.1416" />
    <parent link="link2" />
    <child link="link3" />
    <axis xyz="0 0 -1" />
    <limit lower="-3.14" upper="3.14" effort="10" velocity="3" />
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://fishbot_description/meshes/link4.STL" /></geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="joint4" type="revolute">
    <origin xyz="0.002964 0.018445 0.006" rpy="0 0 0" />
    <parent link="link3" />
    <child link="link4" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14" upper="3.14" effort="10" velocity="3" />
  </joint>
</robot>
